{
	"name": "subak-game",
	"description": "A game where you drop and merge fruit to make larger fruit.",
	"version": "2.0.4",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"validate": "npm run format && npm run lint && npm run test && npm run check",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"author": "",
	"license": "",
	"dependencies": {
		"@dimforge/rapier2d-compat": "^0.16.1",
		"dexie": "^4.0.11",
		"howler": "^2.2.4",
		"jsonwebtoken": "^9.0.3",
		"modern-screenshot": "^4.6.0",
		"pg": "^8.19.0",
		"posthog-js": "^1.298.1",
		"svelte": "^5.0.0",
		"svelte-check": "^4.1.5",
		"vite": "^6.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@poppanator/sveltekit-svg": "^5.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@testing-library/svelte": "^5.2.8",
		"@types/howler": "^2.2.12",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/pg": "^8.16.0",
		"@vitest/browser": "^3.2.4",
		"esm-env": "^1.2.2",
		"globals": "^16.0.0",
		"jsdom": "^24.0.0",
		"knip": "^5.85.0",
		"playwright": "^1.58.2",
		"publint": "^0.3.2",
		"svelte": "5.43.14",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.2.6",
		"vitest": "^3.2.4"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	}
}
